{%- comment -%}
  Product Card Snippet
  Usage: {% render 'product-card', product: product %}
{%- endcomment -%}

<div class="card product-card" id="product-card-{{ product.id }}">
  <a href="{{ product.url }}" class="product-card__link" aria-label="{{ product.title }}">
    <div class="card__image product-card__image">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 600 }}"
          alt="{{ product.featured_image.alt | escape }}"
          width="600"
          height="600"
          loading="lazy"
        >
      {%- else -%}
        <div class="product-card__placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
        </div>
      {%- endif -%}

      {%- if product.compare_at_price > product.price -%}
        {%- assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
        <span class="product-card__badge badge badge--emerald">Save {{ savings }}%</span>
      {%- endif -%}
    </div>

    <div class="card__body product-card__body">
      {%- if product.metafields.reviews.rating.value -%}
        <div class="product-card__rating">
          {% render 'star-rating', rating: product.metafields.reviews.rating.value %}
          <span class="product-card__review-count">({{ product.metafields.reviews.rating_count.value }})</span>
        </div>
      {%- endif -%}

      <h3 class="product-card__title">{{ product.title }}</h3>

      <div class="product-card__price">
        <span class="price">{{ product.price | money }}</span>
        {%- if product.compare_at_price > product.price -%}
          <span class="price price--compare">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
      </div>
    </div>
  </a>

  {%- if product.available -%}
    <div class="product-card__action">
      <button
        class="btn btn--primary btn--full product-card__atc"
        data-quick-add
        data-variant-id="{{ product.selected_or_first_available_variant.id }}"
        aria-label="Add {{ product.title }} to cart"
      >
        Add to Cart
      </button>
    </div>
  {%- else -%}
    <div class="product-card__action">
      <button class="btn btn--secondary btn--full" disabled>Sold Out</button>
    </div>
  {%- endif -%}
</div>

<style>
  .product-card__link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .product-card__image {
    position: relative;
  }
  .product-card__badge {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
  }
  .product-card__placeholder {
    width: 100%;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-bg-alt);
    color: var(--color-text-muted);
  }
  .product-card__rating {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    margin-bottom: var(--space-2);
  }
  .product-card__review-count {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
  .product-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--space-2);
    line-height: var(--leading-snug);
  }
  .product-card__price {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    margin-bottom: var(--space-1);
  }
  .product-card__price .price {
    font-size: var(--text-lg);
  }
  .product-card__action {
    padding: 0 var(--space-5) var(--space-5);
  }
  .product-card__atc {
    opacity: 0;
    transition: opacity var(--transition-base);
  }
  .product-card:hover .product-card__atc {
    opacity: 1;
  }
  @media (max-width: 768px) {
    .product-card__atc {
      opacity: 1;
    }
  }
</style>
