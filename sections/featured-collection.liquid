{%- comment -%} Featured Collection Section {%- endcomment -%}

<section class="featured-collection" id="featured-collection">
  <div class="container">
    <div class="featured-collection__header">
      <span class="overline">{{ section.settings.overline | default: 'Our Products' }}</span>
      <h2 class="featured-collection__title">{{ section.settings.heading | default: 'Bestselling Products' }}</h2>
      <p class="featured-collection__subtitle">{{ section.settings.subheading | default: 'Trusted by thousands for better posture, comfort, and mobility.' }}</p>
    </div>

    <div class="featured-collection__grid">
      {%- assign featured_collection = collections[section.settings.collection] | default: collection -%}
      {%- if featured_collection -%}
        {%- for product in featured_collection.products limit: section.settings.products_to_show -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="card product-card">
            <div class="card__image">
              <div class="product-card__placeholder">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              </div>
            </div>
            <div class="card__body">
              <h3 class="product-card__title">Sample Product {{ i }}</h3>
              <div class="product-card__price">
                <span class="price">$49.99</span>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all and featured_collection -%}
      <div class="featured-collection__link">
        <a href="{{ featured_collection.url }}" class="btn btn--secondary">
          View All Products
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "Our Products"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bestselling Products"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Trusted by thousands for better posture, comfort, and mobility."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View All' button",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}
