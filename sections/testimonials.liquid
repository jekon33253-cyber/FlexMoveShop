{%- comment -%} Testimonials Section {%- endcomment -%}

<section class="testimonials section--alt" id="testimonials">
  <div class="container">
    <div class="testimonials__header">
      <span class="overline">{{ section.settings.overline | default: 'Customer Reviews' }}</span>
      <h2>{{ section.settings.heading | default: 'What Our Customers Say' }}</h2>
      <p class="text-secondary text-lg" style="max-width:600px;margin:var(--space-3) auto 0;">{{ section.settings.subheading | default: 'Join thousands of satisfied customers who have improved their daily comfort with SHOPFLEXMOVE.' }}</p>
    </div>

    <div class="testimonials__grid">
      {%- for block in section.blocks -%}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="testimonial-card__stars">
            {% render 'star-rating', rating: block.settings.rating %}
          </div>
          <p class="testimonial-card__text">"{{ block.settings.text }}"</p>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar">{{ block.settings.name | slice: 0 }}</div>
            <div>
              <p class="testimonial-card__name" style="margin:0;">{{ block.settings.name }}</p>
              <p class="testimonial-card__verified" style="margin:0;">✓ Verified Buyer</p>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "Customer Reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Join thousands of satisfied customers who have improved their daily comfort with SHOPFLEXMOVE."
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review Text"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Customer Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "I've been using the posture corrector for 3 weeks now and the difference is remarkable. My upper back feels so much better after long work days. The quality is outstanding.",
            "name": "Sarah M."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "The lumbar cushion has been a game-changer for my home office setup. I can work all day without the usual lower back fatigue. Worth every penny.",
            "name": "James R."
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "text": "Bought the Recovery Bundle and I'm impressed with the quality. The foam roller and massage balls have become part of my daily routine. Highly recommend!",
            "name": "Emily T."
          }
        }
      ]
    }
  ]
}
{% endschema %}
