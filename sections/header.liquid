{%- comment -%} FlexMove Header — Announcement Bar + Sticky Nav {%- endcomment -%}

{%- assign show_announcement = settings.show_announcement | default: true -%}

{%- if show_announcement -%}
<div class="announcement-bar" id="announcement-bar" role="banner" aria-label="Promotions">
  <div class="announcement-bar__marquee">
    <div class="announcement-bar__track">
      {%- comment -%} Repeat items for seamless loop {%- endcomment -%}
      <span class="announcement-bar__item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4F8CFF" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <span class="announcement-bar__item--highlight">FREE Shipping</span>&nbsp;on orders over $49
      </span>
      <span class="announcement-bar__sep">|</span>
      <span class="announcement-bar__item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4F8CFF" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span class="announcement-bar__item--highlight">30-Day</span>&nbsp;Money-Back Guarantee
      </span>
      <span class="announcement-bar__sep">|</span>
      <span class="announcement-bar__item">
        ⭐⭐⭐⭐⭐&nbsp;<span class="announcement-bar__item--highlight">4.8/5</span>&nbsp;from 2,847 reviews
      </span>
      <span class="announcement-bar__sep">|</span>
      <span class="announcement-bar__item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4F8CFF" stroke-width="2.5"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        <span class="announcement-bar__item--highlight">50,000+</span>&nbsp;Happy Customers
      </span>
      <span class="announcement-bar__sep">|</span>
      {%- comment -%} Duplicate for loop {%- endcomment -%}
      <span class="announcement-bar__item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4F8CFF" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <span class="announcement-bar__item--highlight">FREE Shipping</span>&nbsp;on orders over $49
      </span>
      <span class="announcement-bar__sep">|</span>
      <span class="announcement-bar__item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4F8CFF" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span class="announcement-bar__item--highlight">30-Day</span>&nbsp;Money-Back Guarantee
      </span>
      <span class="announcement-bar__sep">|</span>
      <span class="announcement-bar__item">
        ⭐⭐⭐⭐⭐&nbsp;<span class="announcement-bar__item--highlight">4.8/5</span>&nbsp;from 2,847 reviews
      </span>
      <span class="announcement-bar__sep">|</span>
      <span class="announcement-bar__item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#4F8CFF" stroke-width="2.5"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        <span class="announcement-bar__item--highlight">50,000+</span>&nbsp;Happy Customers
      </span>
      <span class="announcement-bar__sep">|</span>
    </div>
  </div>
</div>
{%- endif -%}

<header class="site-header" id="site-header" role="banner">
  <div class="container">
    <div class="site-header__inner">

      {%- comment -%} FlexMove SVG Logo {%- endcomment -%}
      <a href="/" class="site-header__logo" aria-label="{{ shop.name }} — Home">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 200 }}"
            alt="{{ shop.name }}"
            width="180"
            height="50"
            loading="eager"
          >
        {%- else -%}
          <img
            src="{{ 'logo.png' | asset_url }}"
            alt="{{ shop.name }}"
            width="180"
            height="50"
            style="display:block; max-height: 50px; width: auto;"
            loading="eager"
          >
        {%- endif -%}
      </a>

      {%- comment -%} Desktop Navigation {%- endcomment -%}
      <nav class="site-header__nav" id="main-nav" role="navigation" aria-label="Main navigation">
        {%- for link in section.settings.menu.links -%}
          {%- if link.links.size > 0 -%}
            <div class="site-header__dropdown">
              <a href="{{ link.url }}" class="site-header__nav-link">
                {{ link.title }}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </a>
              <div class="site-header__dropdown-menu">
                {%- for child in link.links -%}
                  <a href="{{ child.url }}" class="site-header__dropdown-link">{{ child.title }}</a>
                {%- endfor -%}
              </div>
            </div>
          {%- else -%}
            <a href="{{ link.url }}" class="site-header__nav-link">{{ link.title }}</a>
          {%- endif -%}
        {%- endfor -%}
      </nav>

      {%- comment -%} Header Actions {%- endcomment -%}
      <div class="site-header__actions">
        <a href="/search" class="site-header__icon-btn" aria-label="Search">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </a>
        <a href="/account" class="site-header__icon-btn hide-mobile" aria-label="Account">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
        <button class="site-header__cart-btn" data-cart-toggle aria-label="Open cart">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          <span class="site-header__cart-count" data-cart-count style="display:none">0</span>
        </button>

        {%- comment -%} Mobile Menu Toggle {%- endcomment -%}
        <button class="site-header__mobile-toggle" id="mobile-menu-toggle" aria-label="Open mobile menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </div>
</header>

{%- comment -%} Mobile Menu {%- endcomment -%}
<nav class="mobile-menu" id="mobile-menu" aria-label="Mobile navigation" style="display:none">
  <div class="mobile-menu__inner">
    <div class="mobile-menu__logo">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 160 36" height="32" aria-label="FlexMove">
        <!-- Premium support arch under the wordmark -->
        <path d="M8 25 Q 48 29, 88 25" stroke="#4F8CFF" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.85"/>
        <text x="8" y="21" font-family="Sora, sans-serif" font-size="16" font-weight="800" fill="#0A2540" letter-spacing="-0.3">Flex</text>
        <text x="44" y="21" font-family="Sora, sans-serif" font-size="16" font-weight="800" fill="#4F8CFF" letter-spacing="-0.3">Move</text>
        <text x="89" y="14" font-family="Sora, sans-serif" font-size="6" font-weight="600" fill="#4F8CFF">®</text>
        <text x="8" y="31" font-family="Plus Jakarta Sans, sans-serif" font-size="5.5" font-weight="600" fill="#718096" letter-spacing="0.8">EST. 2018</text>
      </svg>
    </div>
    {%- for link in section.settings.menu.links -%}
      <a href="{{ link.url }}" class="mobile-menu__link">{{ link.title }}</a>
    {%- endfor -%}
    <hr class="divider">
    <a href="/account" class="mobile-menu__link">Account</a>
    <div class="mobile-menu__trust">
      <span>✅ 30-Day Guarantee</span>
      <span>🚚 Free Shipping $49+</span>
      <span>⭐ 4.8/5 Rating</span>
    </div>
  </div>
</nav>

<style>
  /* ── Header ── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    transition: background var(--transition-base), box-shadow var(--transition-base);
  }

  .site-header.is-scrolled {
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 4px 24px rgba(10, 37, 64, 0.06);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    height: 70px;
  }

  /* Logo */
  .site-header__logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }
  .site-header__logo:hover { opacity: 0.88; }

  /* Nav */
  .site-header__nav {
    display: none;
    align-items: center;
    gap: var(--space-2);
    flex: 1;
    justify-content: center;
  }

  @media (min-width: 990px) {
    .site-header__nav { display: flex; }
  }

  .site-header__nav-link {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: var(--space-2) var(--space-4);
    color: var(--color-navy);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.01em;
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .site-header__nav-link:hover {
    color: var(--color-teal);
    background: rgba(79, 140, 255, 0.08);
  }

  /* Dropdown */
  .site-header__dropdown {
    position: relative;
  }

  .site-header__dropdown-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-2);
    min-width: 180px;
    box-shadow: 0 10px 30px rgba(10, 37, 64, 0.08);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--transition-fast), visibility var(--transition-fast);
    z-index: 10;
  }

  .site-header__dropdown:hover .site-header__dropdown-menu {
    opacity: 1;
    visibility: visible;
  }

  .site-header__dropdown-link {
    display: block;
    padding: var(--space-3) var(--space-4);
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--text-sm);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .site-header__dropdown-link:hover {
    color: var(--color-teal);
    background: rgba(79, 140, 255, 0.08);
  }

  /* Actions */
  .site-header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  .site-header__icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--color-navy);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-fast);
    background: none;
    border: none;
    cursor: pointer;
  }
  .site-header__icon-btn:hover {
    color: var(--color-teal);
    background: rgba(79, 140, 255, 0.08);
  }

  .site-header__cart-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--color-navy);
    background: rgba(79, 140, 255, 0.08);
    border: 1px solid rgba(79, 140, 255, 0.25);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .site-header__cart-btn:hover {
    color: var(--color-teal);
    background: rgba(79, 140, 255, 0.15);
    border-color: rgba(79, 140, 255, 0.4);
  }

  .site-header__cart-count {
    position: absolute;
    top: -6px;
    right: -6px;
    background: var(--color-teal);
    color: var(--color-white);
    font-size: 10px;
    font-weight: 700;
    min-width: 18px;
    height: 18px;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
  }

  /* Mobile toggle */
  .site-header__mobile-toggle {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 36px;
    height: 36px;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    border-radius: var(--radius-md);
    transition: background var(--transition-fast);
  }
  .site-header__mobile-toggle:hover {
    background: rgba(79, 140, 255, 0.08);
  }
  .site-header__mobile-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-navy);
    border-radius: 2px;
    transition: all var(--transition-base);
  }

  @media (min-width: 990px) {
    .site-header__mobile-toggle { display: none; }
  }

  /* Mobile Menu */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--color-white);
    z-index: var(--z-modal);
    overflow-y: auto;
  }

  .mobile-menu__inner {
    padding: var(--space-20) var(--space-6) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .mobile-menu__logo {
    margin-bottom: var(--space-6);
  }

  .mobile-menu__link {
    display: block;
    padding: var(--space-4) 0;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-navy);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
    transition: color var(--transition-fast);
  }

  .mobile-menu__link:hover { color: var(--color-teal); }

  .mobile-menu__trust {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-6);
    padding: var(--space-5);
    background: rgba(79, 140, 255, 0.08);
    border-radius: var(--radius-xl);
    border: 1px solid rgba(79, 140, 255, 0.15);
  }

  .mobile-menu__trust span {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  @media (min-width: 990px) {
    .mobile-menu { display: none !important; }
  }
</style>

<script>
  (function() {
    // Sticky scroll class
    const header = document.getElementById('site-header');
    if (header) {
      const onScroll = function() {
        header.classList.toggle('is-scrolled', window.scrollY > 10);
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

    // Mobile menu toggle
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!toggle || !menu) return;

    toggle.addEventListener('click', function() {
      const isOpen = menu.style.display !== 'none';
      menu.style.display = isOpen ? 'none' : 'block';
      toggle.setAttribute('aria-expanded', !isOpen);
      document.body.style.overflow = isOpen ? '' : 'hidden';
      // Animate hamburger to X
      const spans = toggle.querySelectorAll('span');
      if (!isOpen) {
        spans[0].style.transform = 'rotate(45deg) translateY(7px)';
        spans[1].style.opacity = '0';
        spans[2].style.transform = 'rotate(-45deg) translateY(-7px)';
      } else {
        spans[0].style.transform = '';
        spans[1].style.opacity = '';
        spans[2].style.transform = '';
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image (optional — SVG inline is default)"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
