{%- comment -%} Contact Form Section {%- endcomment -%}

<div class="container contact-section" style="padding: var(--space-8) 0; max-width: 600px; margin: 0 auto;">
  <h1 class="page-title text-center" style="margin-bottom: var(--space-4);">{{ page.title | default: 'Contact Us' }}</h1>
  
  {%- if page.content != blank -%}
    <div class="page-content rte text-center text-secondary" style="margin-bottom: var(--space-6);">
      {{ page.content }}
    </div>
  {%- endif -%}

  {%- form 'contact', class: 'contact-form' -%}
    {%- if form.posted_successfully? -%}
      <div class="alert alert--success" style="padding: var(--space-4); background-color: rgba(15, 76, 67, 0.1); color: var(--color-success); border-radius: var(--radius-md); margin-bottom: var(--space-4);">
        Thank you for contacting us! We will get back to you as soon as possible.
      </div>
    {%- elsif form.errors -%}
      <div class="alert alert--error" style="padding: var(--space-4); background-color: rgba(192, 57, 43, 0.1); color: var(--color-error); border-radius: var(--radius-md); margin-bottom: var(--space-4);">
        {{ form.errors | default_errors }}
      </div>
    {%- endif -%}

    <div class="form-group" style="margin-bottom: var(--space-4);">
      <label for="ContactFormName" style="display: block; margin-bottom: var(--space-2); font-weight: 500;">Name</label>
      <input type="text" id="ContactFormName" name="contact[name]" class="form-control" style="width: 100%; padding: var(--space-3); border: 1px solid var(--color-border); border-radius: var(--radius-md);" placeholder="Your Name" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">
    </div>

    <div class="form-group" style="margin-bottom: var(--space-4);">
      <label for="ContactFormEmail" style="display: block; margin-bottom: var(--space-2); font-weight: 500;">Email <span style="color: var(--color-error);">*</span></label>
      <input type="email" id="ContactFormEmail" name="contact[email]" class="form-control" style="width: 100%; padding: var(--space-3); border: 1px solid var(--color-border); border-radius: var(--radius-md);" placeholder="your.email@example.com" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" required aria-required="true">
    </div>

    <div class="form-group" style="margin-bottom: var(--space-4);">
      <label for="ContactFormPhone" style="display: block; margin-bottom: var(--space-2); font-weight: 500;">Phone Number</label>
      <input type="tel" id="ContactFormPhone" name="contact[phone]" class="form-control" style="width: 100%; padding: var(--space-3); border: 1px solid var(--color-border); border-radius: var(--radius-md);" placeholder="Your Phone Number" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}">
    </div>

    <div class="form-group" style="margin-bottom: var(--space-6);">
      <label for="ContactFormMessage" style="display: block; margin-bottom: var(--space-2); font-weight: 500;">Message <span style="color: var(--color-error);">*</span></label>
      <textarea rows="6" id="ContactFormMessage" name="contact[body]" class="form-control" style="width: 100%; padding: var(--space-3); border: 1px solid var(--color-border); border-radius: var(--radius-md); font-family: inherit;" placeholder="How can we help you?" required aria-required="true">{% if form.body %}{{ form.body }}{% endif %}</textarea>
    </div>

    <button type="submit" class="btn btn--primary" style="width: 100%; padding: var(--space-3); border: none; border-radius: var(--radius-md); font-weight: 600; cursor: pointer;">Send Message</button>
  {%- endform -%}
</div>

{% schema %}
{
  "name": "Contact Form",
  "settings": [],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}
