{%- comment -%} FlexMove — Comparison Table Section (killer conversion section) {%- endcomment -%}

<section class="comparison-table" id="comparison-table">
  <div class="container">
    <div class="comparison-table__header">
      <span class="overline">{{ section.settings.overline | default: 'Why FlexMove Wins' }}</span>
      <h2>{{ section.settings.heading | default: 'See the Difference' }}</h2>
      <p class="text-secondary text-lg" style="max-width:600px;margin:var(--space-4) auto 0;">
        {{ section.settings.subheading | default: "Not all knee supports are created equal. See why 50,000+ customers chose FlexMove over the alternatives." }}
      </p>
    </div>

    <div class="comparison-table__wrapper">
      <table class="comparison-table__table" role="table">
        <thead>
          <tr>
            <th scope="col" class="comparison-table__feature-col">Feature</th>
            <th scope="col" class="comparison-table__our-col">
              <div class="comparison-table__our-header">
                <div class="comparison-table__our-badge">⭐ Best Choice</div>
                <div class="comparison-table__brand-name">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 24" height="20" aria-label="FlexMove">
                    <text x="0" y="18" font-family="Sora, sans-serif" font-size="16" font-weight="800" fill="#0A2540">Flex</text>
                    <text x="38" y="18" font-family="Sora, sans-serif" font-size="16" font-weight="800" fill="#4F8CFF">Move</text>
                  </svg>
                  <span>KneeSystem™</span>
                </div>
              </div>
            </th>
            <th scope="col">Generic<br>Knee Brace</th>
            <th scope="col">Surgery /<br>Physical Therapy</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td data-label="Feature">Instant Pain Relief</td>
            <td data-label="FlexMove" class="comparison-table__our-cell"><span class="comparison-table__yes">✓</span></td>
            <td data-label="Generic"><span class="comparison-table__partial">⚠</span></td>
            <td data-label="Surgery"><span class="comparison-table__partial">⚠</span></td>
          </tr>
          <tr>
            <td data-label="Feature">Wearable All Day</td>
            <td data-label="FlexMove" class="comparison-table__our-cell"><span class="comparison-table__yes">✓</span></td>
            <td data-label="Generic"><span class="comparison-table__partial">⚠</span></td>
            <td data-label="Surgery"><span class="comparison-table__no">✗</span></td>
          </tr>
          <tr>
            <td data-label="Feature">Fits Under Clothing</td>
            <td data-label="FlexMove" class="comparison-table__our-cell"><span class="comparison-table__yes">✓</span></td>
            <td data-label="Generic"><span class="comparison-table__no">✗</span></td>
            <td data-label="Surgery"><span class="comparison-table__no">✗</span></td>
          </tr>
          <tr>
            <td data-label="Feature">Medical-Grade Support</td>
            <td data-label="FlexMove" class="comparison-table__our-cell"><span class="comparison-table__yes">✓</span></td>
            <td data-label="Generic"><span class="comparison-table__no">✗</span></td>
            <td data-label="Surgery"><span class="comparison-table__yes">✓</span></td>
          </tr>
          <tr>
            <td data-label="Feature">No Recovery Time</td>
            <td data-label="FlexMove" class="comparison-table__our-cell"><span class="comparison-table__yes">✓</span></td>
            <td data-label="Generic"><span class="comparison-table__yes">✓</span></td>
            <td data-label="Surgery"><span class="comparison-table__no">✗</span></td>
          </tr>
          <tr>
            <td data-label="Feature">Works for Arthritis</td>
            <td data-label="FlexMove" class="comparison-table__our-cell"><span class="comparison-table__yes">✓</span></td>
            <td data-label="Generic"><span class="comparison-table__partial">⚠</span></td>
            <td data-label="Surgery"><span class="comparison-table__partial">⚠</span></td>
          </tr>
          <tr>
            <td data-label="Feature">Doctor Recommended</td>
            <td data-label="FlexMove" class="comparison-table__our-cell"><span class="comparison-table__yes">✓</span></td>
            <td data-label="Generic"><span class="comparison-table__no">✗</span></td>
            <td data-label="Surgery"><span class="comparison-table__yes">✓</span></td>
          </tr>
          <tr class="comparison-table__price-row">
            <td data-label="Feature"><strong>Typical Cost</strong></td>
            <td data-label="FlexMove" class="comparison-table__our-cell">
              <div class="comparison-table__price">
                <strong style="color:var(--color-teal)">$54</strong>
                <small style="color:var(--color-text-muted);text-decoration:line-through;">$79</small>
              </div>
            </td>
            <td data-label="Generic"><span style="color:var(--color-text-secondary)">$15 – $90</span></td>
            <td data-label="Surgery"><span style="color:var(--color-error);font-weight:600;">$3,000 – $15,000+</span></td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="comparison-table__cta">
      <a href="{{ section.settings.cta_url | default: '/products/flexmove-knee-system' }}" class="btn btn--primary btn--large" id="comparison-cta">
        Get FlexMove KneeSystem™ — $54
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
      <p style="color:var(--color-text-muted);font-size:var(--text-sm);margin-top:var(--space-3);margin-bottom:0;">Save $25 today • 30-day money-back guarantee</p>
    </div>
  </div>
</section>

<style>
  .comparison-table {
    padding: var(--section-spacing) 0;
    background: var(--color-bg-alt);
  }

  .comparison-table__header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .comparison-table__wrapper {
    overflow-x: auto;
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-xl);
  }

  .comparison-table__table {
    width: 100%;
    border-collapse: collapse;
    background: var(--color-white);
    border-radius: var(--radius-2xl);
    overflow: hidden;
  }

  .comparison-table__table thead tr {
    background: var(--color-navy);
  }

  .comparison-table__table thead th {
    padding: var(--space-5) var(--space-6);
    text-align: center;
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    border-bottom: 2px solid rgba(255, 255, 255, 0.08);
    white-space: nowrap;
  }

  .comparison-table__feature-col {
    text-align: left !important;
    color: rgba(255, 255, 255, 0.5) !important;
    width: 30%;
  }

  .comparison-table__our-col {
    background: rgba(79, 140, 255, 0.08) !important;
    border-left: 2px solid rgba(79, 140, 255, 0.2) !important;
    border-right: 2px solid rgba(79, 140, 255, 0.2) !important;
    color: var(--color-white) !important;
  }

  .comparison-table__our-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .comparison-table__our-badge {
    background: var(--gradient-teal);
    color: var(--color-navy);
    font-size: 10px;
    font-weight: 800;
    padding: 3px 10px;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .comparison-table__brand-name {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .comparison-table__brand-name span {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.6);
    font-weight: 400;
  }

  .comparison-table__table tbody tr {
    border-bottom: 1px solid var(--color-border-light);
    transition: background var(--transition-fast);
  }

  .comparison-table__table tbody tr:hover {
    background: var(--color-bg-alt);
  }

  .comparison-table__table tbody tr:last-child {
    border-bottom: none;
  }

  .comparison-table__table tbody td {
    padding: var(--space-4) var(--space-6);
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    vertical-align: middle;
  }

  .comparison-table__table tbody td:first-child {
    text-align: left;
    color: var(--color-text);
    font-weight: var(--font-weight-medium);
  }

  .comparison-table__our-cell {
    background: rgba(79, 140, 255, 0.03);
    border-left: 2px solid rgba(79, 140, 255, 0.1);
    border-right: 2px solid rgba(79, 140, 255, 0.1);
  }

  .comparison-table__price-row {
    background: var(--color-bg-warm);
  }

  .comparison-table__price {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-size: var(--text-xl);
  }

  /* Icons */
  .comparison-table__yes {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: rgba(79, 140, 255, 0.12);
    border-radius: 50%;
    color: var(--color-teal);
    font-size: 14px;
    font-weight: 900;
  }

  .comparison-table__no {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: rgba(229, 62, 62, 0.08);
    border-radius: 50%;
    color: var(--color-error);
    font-size: 14px;
    font-weight: 700;
  }

  .comparison-table__partial {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: rgba(244, 185, 66, 0.12);
    border-radius: 50%;
    color: var(--color-warning);
    font-size: 14px;
  }

  /* CTA */
  .comparison-table__cta {
    text-align: center;
    margin-top: var(--space-12);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .comparison-table__table thead th:nth-child(4) { display: none; }
    .comparison-table__table tbody td:nth-child(4) { display: none; }
  }
</style>

{% schema %}
{
  "name": "Comparison Table",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "Why FlexMove Wins"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See the Difference"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Not all knee supports are created equal. See why 50,000+ customers chose FlexMove over the alternatives."
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Button URL"
    }
  ],
  "presets": [
    {
      "name": "Comparison Table"
    }
  ]
}
{% endschema %}
